<div data-controller="template-form">
  <%= form_with model: @template, class: "template-form", data: { action: "submit->template-form#submit", turbo_frame: "_top" } do |f| %>
    <div class="form-group">
      <%= f.label :name, "Nome do Template", class: "form-label" %>
      <%= f.text_field :name, class: "form-control", placeholder: "Digite o nome do template", required: true %>
    </div>

    <div class="questions-section" data-template-form-target="questionsContainer">
      <div data-template-form-target="questions">
        <% if @template.persisted? && @template.question_set&.data.present? %>
          <% @template.question_set.data.each do |question_data| %>
            <div class="question-item" data-template-form-target="questionItem">
              <div class="question-content">
                <div class="question-fields">
                  <div class="question-field-group">
                    <label class="question-label">Tipo</label>
                    <select class="question-type-select">
                      <option value="text" <%= 'selected' if question_data['type'] == 'text' %>>Text</option>
                    </select>
                  </div>
                  <div class="question-field-group">
                    <label class="question-label">Pergunta</label>
                    <input type="text"
                           class="question-input"
                           placeholder="Digite a pergunta"
                           value="<%= question_data['question'] %>">
                  </div>
                </div>
                <button type="button"
                        class="btn-remove-question"
                        data-action="click->template-form#removeQuestion"
                        title="Remover pergunta">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                  </svg>
                </button>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="add-question-wrapper">
        <button type="button"
                class="btn-add-question"
                data-action="click->template-form#addQuestion"
                title="Adicionar pergunta">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
        </button>
      </div>
    </div>

    <%= f.fields_for :question_set, @template.question_set do |qs| %>
      <%= qs.hidden_field :id if @template.persisted? %>
    <% end %>

    <div class="form-actions">
      <%= f.submit @template.persisted? ? "Atualizar" : "Criar", class: "btn-submit" %>
    </div>
  <% end %>
</div>
