<% content_for :page_title, "Gerenciamento - Templates" %>

<div data-controller="modal">
  <%= turbo_frame_tag "template_modal" do %>
    <%= render 'templates/template_modal' %>
  <% end %>

  <%= render 'shared/page_container', title: 'Templates' do %>
  <div class="templates-grid">
    <% @templates.each do |template| %>
      <div class="template-card">
        <div class="template-card-content">
          <h3 class="template-card-title"><%= template.name %></h3>

          <div class="template-card-actions">
            <%= link_to edit_template_path(template),
                class: "btn-icon btn-edit",
                title: "Edit",
                data: { turbo_frame: "template_modal" } do %>
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
              </svg>
            <% end %>

            <%= button_to template_path(template),
              method: :delete,
              class: "btn-icon btn-delete",
              title: "Delete",
              form: {
                data: {
                  turbo_confirm: "Are you sure you want to delete this template?",
                },
              } do %>
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <polyline points="3 6 5 6 21 6"></polyline>
                <path
                  d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"
                ></path>
              </svg>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <button type="button"
            class="template-card add-template-card"
            data-action="click->modal#open">
      <div class="add-template-icon">
        <svg
          width="48"
          height="48"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
      </div>
    </button>
  </div>
  <% end %>

  <%# Question Template (hidden, used for cloning) %>
  <template id="question-template">
    <div class="question-item" data-template-form-target="questionItem">
      <div class="question-content">
        <div class="question-fields">
          <div class="question-field-group">
            <label class="question-label">Tipo</label>
            <select class="question-type-select" data-action="change->template-form#toggleOptions">
              <option value="text">Text</option>
              <option value="radio">Radio</option>
            </select>
          </div>
          <div class="question-field-group">
            <label class="question-label">Texto</label>
            <input type="text"
                   class="question-input"
                   placeholder="Digite a pergunta">
          </div>
          <div class="question-options" style="display: none;">
            <label class="question-label">Opções</label>
            <div class="options-list">
              <%# Options will be added dynamically %>
            </div>
            <div class="add-option-wrapper">
              <button type="button"
                      class="btn-add-option"
                      data-action="click->template-form#addOption"
                      title="Adicionar opção">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              </button>
            </div>
          </div>
        </div>
        <button type="button"
                class="btn-remove-question"
                data-action="click->template-form#removeQuestion"
                title="Remover pergunta">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>
  </template>

  <%# Option Template (hidden, used for cloning) %>
  <template id="option-template">
    <div class="option-item">
      <input type="text"
             class="option-input"
             placeholder="Digite a opção">
      <button type="button"
              class="btn-remove-option"
              data-action="click->template-form#removeOption">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </template>
</div>
