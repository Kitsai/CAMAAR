<%= turbo_frame_tag "template_modal" do %>
  <div class="modal-overlay active"
       id="modalOverlay"
       data-modal-target="overlay"
       data-action="click->modal#closeOnOverlay"></div>

  <div class="modal active" id="modal" data-modal-target="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title">Editar Template</h2>
      </div>

      <div class="modal-body">
        <%= render 'templates/form' %>
      </div>
    </div>
  </div>

  <script>
    // Ensure body overflow is hidden when modal is loaded via Turbo Frame
    document.body.style.overflow = 'hidden'
  </script>

  <%# Question Template (hidden, used for cloning) %>
  <template id="question-template">
    <div class="question-item" data-template-form-target="questionItem">
      <div class="question-content">
        <div class="question-fields">
          <div class="question-field-group">
            <label class="question-label">Tipo</label>
            <select class="question-type-select" data-action="change->template-form#toggleOptions">
              <option value="text">Text</option>
              <option value="radio">Radio</option>
            </select>
          </div>
          <div class="question-field-group">
            <label class="question-label">Texto</label>
            <input type="text"
                   class="question-input"
                   placeholder="Digite a pergunta">
          </div>
          <div class="question-options" style="display: none;">
            <label class="question-label">Opções</label>
            <div class="options-list">
              <%# Options will be added dynamically %>
            </div>
            <div class="add-option-wrapper">
              <button type="button"
                      class="btn-add-option"
                      data-action="click->template-form#addOption"
                      title="Adicionar opção">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              </button>
            </div>
          </div>
        </div>
        <button type="button"
                class="btn-remove-question"
                data-action="click->template-form#removeQuestion"
                title="Remover pergunta">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>
  </template>

  <%# Option Template (hidden, used for cloning) %>
  <template id="option-template">
    <div class="option-item">
      <input type="text"
             class="option-input"
             placeholder="Digite a opção">
      <button type="button"
              class="btn-remove-option"
              data-action="click->template-form#removeOption">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </template>
<% end %>
