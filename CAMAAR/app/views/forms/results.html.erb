<% content_for :page_title, "Formulários Criados" %>

<%= render 'shared/page_container', title: 'Formulários Criados' do %>
  <% if @forms.any? %>
    <div class="templates-grid">
      <% @forms.each do |form| %>
        <div class="template-card">
          <div class="template-card-content" style="display: flex; flex-direction: column; align-items: flex-start; text-align: left;">
            <div style="display: flex; align-items: center; gap: 0.5rem; width: 100%; margin-bottom: 0.1rem;">
              <h3 class="template-card-title" style="margin: 0; flex: 1;"><%= form.course.name %></h3>
            </div>
            <p class="template-card-subtitle" style="color: #718096; margin: 0 0 0.3rem 0; font-size: 0.9rem;">
              <%= form.course.semester %>
            </p>
            <p class="form-card-details" style="margin: 0; color: #4a5568;">
              Professor: <%= form.course.teacher.name %>
            </p>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <svg
        width="64"
        height="64"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        style="color: #cbd5e0; margin-bottom: 1rem;"
      >
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
        <line x1="16" y1="13" x2="8" y2="13"></line>
        <line x1="16" y1="17" x2="8" y2="17"></line>
        <polyline points="10 9 9 9 8 9"></polyline>
      </svg>
      <h3 style="color: #4a5568; margin-bottom: 0.5rem;">Nenhum formulário criado</h3>
      <p style="color: #718096;">Você ainda não criou nenhum formulário.</p>
    </div>
  <% end %>
<% end %>
