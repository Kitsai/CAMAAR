<% content_for :page_title, "Avaliações" %>

<%= render 'shared/page_container', title: 'Avaliações' do %>
  <%= turbo_frame_tag "form_modal" %>

  <% if @forms.any? %>
    <div class="templates-grid">
      <% @forms.each do |form| %>
        <%= link_to form_path(form), 
            data: { turbo_frame: "form_modal" },
            class: "template-card", 
            style: "text-decoration: none; color: inherit; cursor: pointer;" do %>
          <div class="template-card-content" style="display: flex; flex-direction: column; align-items: flex-start; text-align: left;">
            <div style="display: flex; align-items: center; gap: 0.5rem; width: 100%; margin-bottom: 0.1rem;">
              <h3 class="template-card-title" style="margin: 0; flex: 1;"><%= form.course.name %></h3>
              <% if current_user == form.course.teacher %>
                <span style="background-color: #4299e1; color: white; padding: 0.25rem 0.5rem; border-radius: 0.25rem; font-size: 0.75rem; font-weight: 600;">
                  Professor
                </span>
              <% end %>
            </div>
            <p class="template-card-subtitle" style="color: #718096; margin: 0 0 0.3rem 0; font-size: 0.9rem;">
              <%= form.course.semester %>
            </p>
            <p class="form-card-details" style="margin: 0; color: #4a5568;">
              Professor: <%= form.course.teacher.name %>
            </p>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <svg
        width="64"
        height="64"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        style="color: #cbd5e0; margin-bottom: 1rem;"
      >
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
        <line x1="16" y1="13" x2="8" y2="13"></line>
        <line x1="16" y1="17" x2="8" y2="17"></line>
        <polyline points="10 9 9 9 8 9"></polyline>
      </svg>
      <h3 style="color: #4a5568; margin-bottom: 0.5rem;">Nenhuma avaliação pendente</h3>
      <p style="color: #718096;">Você não possui avaliações para responder no momento.</p>
    </div>
  <% end %>

  <h2>Turmas</h2>

  <div class="templates-grid">
    <% @courses.each do |course| %>
      <div class="template-card">
        <div class="template-card-content">
          <h3 class="template-card-title"><%= link_to course.name, turma_path(course) %></h3>
          <p class="template-card-subtitle"><%= course.code if course.respond_to?(:code) %></p>
          <p class="form-card-details"><%= course.description.truncate(120) if course.respond_to?(:description) %></p>
        </div>
      </div>
    <% end %>
  </div>

  <% if @courses.empty? %>
    <div class="empty-state">
      Nenhuma turma encontrada.
    </div>
  <% end %>
<% end %>
