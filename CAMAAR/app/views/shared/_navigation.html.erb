<nav class="navbar">
  <div class="navbar-left">
    <button class="navbar-menu-btn" id="menuToggle" aria-label="Toggle menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <h1 class="navbar-title"><%= content_for?(:page_title) ? yield(:page_title) : 'CAMAAR' %></h1>
  </div>

  <% if logged_in? %>
    <div class="navbar-right">
      <div class="user-avatar">
        <%= current_user.name&.first&.upcase || current_user.email.first.upcase %>
      </div>
      <%= button_to logout_path, method: :delete, class: "logout-btn", title: "Logout" do %>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
          <polyline points="16 17 21 12 16 7"></polyline>
          <line x1="21" y1="12" x2="9" y2="12"></line>
        </svg>
      <% end %>
    </div>
  <% end %>
</nav>
