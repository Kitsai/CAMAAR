<div class="modal-overlay"
     id="modalOverlay"
     data-modal-target="overlay"
     data-action="click->modal#closeOnOverlay"></div>

<div class="modal form-modal" id="modal" data-modal-target="modal">
  <div class="modal-box" data-controller="create-form">
    <div class="field-group">
      <label for="templateSelect">Template:</label>
      <select 
        id="templateSelect" 
        name="selected_template"
        data-create-form-target="select"
        data-action="change->create-form#add"
        class="custom-select"
      >
        <option value="">Template</option>

        <% @templates.each do |template| %>
          <option 
            value="<%= template.id %>"
            data-name="<%= template.name %>"
            data-semester="2025.2"
            data-code="TMP0123"
          >
            <%= template.name %>
          </option>
        <% end %>
      </select>
    </div>

    <div class="template-info" data-create-form-target="list">
      <div class="template-info-header">
        <span>Nome</span>
        <div class="spacer">
          <span>Semestre</span>
          <span>Código</span>
        </div>
      </div>

      <div class="info-item">
        <input type="checkbox" class="green-checkbox">
        <div class="info-item-content">
          <div class="item-content"> 
            <span>Template Exemplo</span>
            <div class="spacer">
              <span>2024.1</span>
              <span>TMP001</span>
            </div>
          </div>
          <div class="divider"></div>
        </div>
      </div>

      <div class="info-item">
        <input type="checkbox" class="green-checkbox">
        <div class="info-item-content">
          <div class="item-content"> 
            <span>Template Exemplo</span>
            <div class="spacer">
              <span>2024.1</span>
              <span>TMP001</span>
            </div>
          </div>
          <div class="divider"></div>
        </div>
      </div>

    </div>
    <div class="modal-footer">
      <button 
        class="btn-submit"
        data-action="click->create-form#submitForms"
      >
        Enviar
      </button>
    </div>
  </div>
</div>