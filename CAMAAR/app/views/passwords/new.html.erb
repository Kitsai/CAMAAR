<div class="login_container">
  <div class="login_content">
    <div class="login_form">
      <h1>Definir Senha</h1>

      <%= form_with url: set_password_path, method: :post, local: true do |f| %>
        <%= f.hidden_field :email, value: @user&.email || params[:email] %>

        <div class="form-group">
          <%= f.label :password, "Senha" %>
          <%= f.password_field :password,
                           class: "form-control",
                           placeholder: "Digite sua senha",
                           required: true %>
        </div>

        <div class="form-group">
          <%= f.label :password_confirmation, "Confirmar" %>
          <%= f.password_field :password_confirmation,
                           class: "form-control",
                           placeholder: "Confirme sua senha",
                           required: true %>
        </div>

        <div class="form-group">
          <%= f.submit "Definir Senha", class: "button" %>
        </div>
      <% end %>
    </div>
    <div class="welcome">
      <b>
        Bem vindo<br>
        ao<br>
        Camaar
      </b>
    </div>
  </div>
</div>
